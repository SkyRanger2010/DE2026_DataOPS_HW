# PostgreSQL (сервис db)
POSTGRES_USER=airflow_user
POSTGRES_PASSWORD=airflow_placeholder_password
POSTGRES_DB=airflow_db

# Airflow: подключение к БД (те же учётные данные, хост db = имя сервиса в compose)
# В docker-compose подставляется через AIRFLOW__DATABASE__SQL_ALCHEMY_CONN
# Формат: postgresql+psycopg2://USER:PASSWORD@db:5432/DATABASE

# Права на файлы в контейнере (Linux: AIRFLOW_UID=$(id -u))
AIRFLOW_UID=50000
