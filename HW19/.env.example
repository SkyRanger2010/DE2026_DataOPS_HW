# PostgreSQL (сервис db)
POSTGRES_USER=lakefs_user
POSTGRES_PASSWORD=lakefs_placeholder_password
POSTGRES_DB=lakefs_db

# MinIO (сервис minio) — те же ключи использует LakeFS для доступа к S3
MINIO_ROOT_USER=minio_user
MINIO_ROOT_PASSWORD=minio_placeholder_password

# LakeFS: секрет для шифрования (ненастоящий, длинная строка)
LAKEFS_AUTH_ENCRYPT_SECRET_KEY=placeholder-secret-key-for-lakefs-auth-32chars-min
